#!/bin/bash

VERSION="v1.19.24"
MIRROR="${MIRROR:-https://mirror.ghproxy.com/}"

# Helper function for dynamic config directory
get_config_dir() {
    local default_dir="/etc/mihomo"
    local config_file="${HOME}/.config/mihomo/config-dir.conf"

    if [ -f "$config_file" ]; then
        local saved_dir
        saved_dir=$(cat "$config_file" 2>/dev/null)
        if [ -n "$saved_dir" ] && [ -d "$saved_dir" ]; then
            echo "$saved_dir"
            return
        fi
    fi
    echo "$default_dir"
}

# 系统级目录（FHS 标准）
INSTALL_DIR="/usr/local/bin"
CONFIG_DIR=$(get_config_dir)
CACHE_DIR="/var/cache/mihomo"
SYSTEMD_DIR="/etc/systemd/system"
CONFIG_REPO_DIR="${CONFIG_DIR}/profiles"
MANUAL_CONFIG_DIR="${CONFIG_DIR}/manual"
UI_DIR="${CONFIG_DIR}/ui"
# LOG_DIR="/var/log/mihomo"  # Unused - reserved for future use

UI_REPO="https://github.com/Zephyruso/zashboard/releases/download/latest/dist-no-fonts.zip"
VERBOSE="${VERBOSE:-0}"
USER_AGENT="${USER_AGENT:-Clash/v1.18.0}"

# Preset User-Agents
declare -A UA_PRESETS=(
     ["clash"]="Clash/v1.18.0"
     ["clashmeta"]="ClashMeta/v1.15.0"
     ["mihomo"]="mihomo/v1.19.0"
     ["surge"]="Surge/4.1500"
     ["quantumult"]="Quantumult/1.0.9"
     ["shadowrocket"]="Shadowrocket/2.1.91"
     ["mozilla"]="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
     ["chrome"]="Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36"
     ["curl"]="curl/7.81.0"
)

# XDG 数据目录（存储配置源）
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
# SOURCES_FILE="${XDG_DATA_HOME}/mihomo/sources.conf"  # Unused - see get_sources_file()

get_sources_file() {
    local data_dir="${XDG_DATA_HOME:-$HOME/.local/share}"
    mkdir -p "$data_dir/mihomo"
    echo "${data_dir}/mihomo/sources.conf"
}

log_info() { echo "[INFO] $1"; }
log_error() { echo "[ERROR] $1" >&2; }
log_debug() { [[ $VERBOSE == "1"  ]] && echo "[DEBUG] $1"; }

get_ua() {
    local ua_input="$1"

    # If it's a preset name, expand it
    if [[ -v "UA_PRESETS[$ua_input]" ]]; then
        echo "${UA_PRESETS[$ua_input]}"
    else
        # Otherwise, use it as-is (custom UA string)
        echo "$ua_input"
    fi
}

list_ua_presets() {
    echo "Available User-Agent presets:"
    echo ""
    for preset in "${!UA_PRESETS[@]}"; do
        printf "  %-15s %s\n" "$preset" "${UA_PRESETS[$preset]}"
    done | sort
    echo ""
    echo "Usage:"
    echo "  mihomoctl config download mysub --ua mozilla"
    echo "  mihomoctl config download mysub --ua 'Custom-UA'"
}

get_manual_configs() {
    [ -d "$MANUAL_CONFIG_DIR" ] && find "$MANUAL_CONFIG_DIR" -maxdepth 1 -name '*.yaml' -printf '%f\n' 2>/dev/null | sed 's/\.yaml$//'
}

get_profile_configs() {
    [ -d "$CONFIG_REPO_DIR" ] && find "$CONFIG_REPO_DIR" -maxdepth 1 -name '*.yaml' -printf '%f\n' 2>/dev/null
}

get_all_configs() {
    local configs=""
    configs=$(get_manual_configs)
    configs="$configs $(get_profile_configs)"
    echo "$configs"
}

get_sources() {
    local sources_file
    sources_file=$(get_sources_file)
    [ -f "$sources_file" ] && cut -d'|' -f1 "$sources_file"
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log_error "This script must be run as root. Use: sudo mihomoctl $*"
        exit 1
    fi
}

check_deps() {
    local missing=""
    for cmd in curl gunzip jq grep sed; do
        command -v "$cmd" >/dev/null 2>&1 || missing="$missing $cmd"
    done
    if [ -n "$missing" ]; then
        log_error "Missing commands:$missing"
        exit 1
    fi
}
check_deps

# 特定命令需要 root 权限
case "${1:-}" in
    install | uninstall | start | stop | restart | enable | disable | ui)
        check_root "$@"
        ;;
    config)
        case "${2:-}" in
            download | select | create | edit)
                check_root "$@"
                ;;
            add | remove | list | show)
                ;;
        esac
        ;;
    status | logs | --help | -h)
        ;;
esac

ARCH=$(uname -m)
case "$ARCH" in
    x86_64)     MIRROR_ARCH="linux-amd64" ;;
    aarch64 | arm64) MIRROR_ARCH="linux-arm64" ;;
    *)
                log_error "Unsupported architecture: $ARCH"
                                                             exit 1
                                                                    ;;
esac

get_cache_path() {
    local url="$1"
    local filename
    filename=$(basename "$url" | sed 's/?.*//')
    echo "${CACHE_DIR}/${filename}"
}

get_uncompressed_path() {
    local cached_gz="$1"
    echo "${cached_gz%.gz}.bin"
}

ensure_allow_lan() {
    local config_file="$1"

    if [ ! -f "$config_file" ]; then
        log_error "Config file not found: $config_file"
        return 1
    fi

    # 检查是否已经有 allow-lan 配置
    if grep -q "^allow-lan:" "$config_file" 2>/dev/null; then
        # 更新现有的 allow-lan 为 true
        sed -i 's/^allow-lan:.*$/allow-lan: true/' "$config_file"
        log_debug "Updated allow-lan to true"
    else
        # 添加 allow-lan: true（在配置开头，作为重要配置）
        sed -i '1i allow-lan: true' "$config_file"
        log_debug "Added allow-lan: true"
    fi
}

curl_progress() {
    local url="$1"
    local output="$2"
    local force_download="${3:-0}"
    mkdir -p "$CACHE_DIR"

    local cached_file
    cached_file=$(get_cache_path "$url")
    local uncached_file
    uncached_file=$(get_uncompressed_path "$cached_file")

    log_info "Downloading: $url"

    # 如果强制下载，跳过缓存检查
    if [ "$force_download" = "0" ]; then
        if [ -f "$uncached_file" ]; then
            log_info "Cache found: $uncached_file (decompressed binary)"
            cp "$uncached_file" "$output"
            return 0
        fi

        if [ -f "$cached_file" ]; then
            log_info "Cache found: $cached_file (compressed)"
            cp "$cached_file" "$output"
            return 0
        fi
    else
        log_info "Force download: ignoring cache"
    fi

    curl -k -L -# -A "$USER_AGENT" --connect-timeout 30 -m 60 -o "$output" "$url" || {
        local err=$?
        log_error "curl failed with code $err"
        return $err
    }

    if [ -f "$output" ]; then
        cp "$output" "$cached_file"
        log_info "Cached: $cached_file"
    fi
}

cache_uncompressed() {
    local gz_file="$1"
    local bin_file
    bin_file=$(get_uncompressed_path "$gz_file")

    if [ ! -f "$bin_file" ]; then
        gunzip -c "$gz_file" >"$bin_file"
        chmod +x "$bin_file"
        log_info "Cached binary: $bin_file"
    fi
}

do_install() {
    local force_download=0
    local config_dir="/etc/mihomo"

    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f | --force)
                force_download=1
                log_info "Force download enabled"
                shift
                ;;
            --config-dir)
                if [ -z "$2" ]; then
                    log_error "--config-dir requires a directory path"
                    exit 1
                fi
                config_dir="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    log_info "Starting mihomo user-level installation..."
    log_info "Version: $VERSION, Arch: $MIRROR_ARCH"
    log_info "Config directory: $config_dir"

    # Save config directory preference for other commands
    if [ "$config_dir" != "/etc/mihomo" ]; then
        mkdir -p "${HOME}/.config/mihomo"
        echo "$config_dir" >"${HOME}/.config/mihomo/config-dir.conf"
        log_info "Saved config directory preference: $config_dir"
    fi

    local url="${MIRROR}https://github.com/MetaCubeX/mihomo/releases/download/${VERSION}/mihomo-${MIRROR_ARCH}-v2-${VERSION}.gz"
    local tmpfile
    tmpfile=$(mktemp)
    log_debug "Temp file: $tmpfile"

    trap 'rm -f "$tmpfile" "${tmpfile}.uncompressed"' EXIT

    log_info "Downloading mihomo binary..."
    if ! curl_progress "$url" "$tmpfile" "$force_download"; then
        log_error "Mirror failed, trying direct..."
        url="https://github.com/MetaCubeX/mihomo/releases/download/${VERSION}/mihomo-${MIRROR_ARCH}-v2-${VERSION}.gz"
        curl_progress "$url" "$tmpfile" "$force_download" || {
            log_error "Download failed"
            exit 1
        }
    fi

    log_info "Processing binary..."
    local binary_file="$tmpfile"
    local file_type
    file_type=$(file "$tmpfile" 2>/dev/null || echo "unknown")

    if echo "$file_type" | grep -q "gzip"; then
        log_debug "File is gzip format, decompressing..."
        gunzip -c "$tmpfile" >"${tmpfile}.uncompressed"  2>/dev/null || {
            log_error "Decompress failed"
            exit 1
        }

        local cached_gz
        cached_gz=$(get_cache_path "$url")
        if [ ! -f "$cached_gz" ]; then
            cp "$tmpfile" "$cached_gz"
            log_info "Cached: $cached_gz"
        fi
        cache_uncompressed "$cached_gz"

        binary_file="${tmpfile}.uncompressed"
    else
        log_debug "File is already in binary format (from cache)"
    fi

    if [ ! -f "$binary_file" ]; then
        log_error "Binary file not found: $binary_file"
        exit 1
    fi

    log_debug "Binary size: $(du -h "$binary_file" | cut -d' ' -f1)"

    mkdir -p "$INSTALL_DIR"
    log_info "Installing to ${INSTALL_DIR}..."
    chmod +x "$binary_file"
    mv "$binary_file" "${INSTALL_DIR}/mihomo" || {
        log_error "Failed to install mihomo"
        exit 1
    }
    trap - EXIT
    log_info "Installed: $(du -h "${INSTALL_DIR}/mihomo" | cut -d' ' -f1)"

    mkdir -p "$config_dir" "$CONFIG_REPO_DIR"
    log_info "Creating config directory ${config_dir}..."

    if [ ! -f "${config_dir}/config.yaml" ]; then
        cat >"${config_dir}/config.yaml"  <<'EOF'
mixed-port: 7890
allow-lan: true
mode: rule
log-level: info
external-controller: 127.0.0.1:9090
EOF
        log_info "Created default config: ${config_dir}/config.yaml"
    fi

    mkdir -p "$SYSTEMD_DIR"
    log_info "Installing systemd system service..."
    cat >"${SYSTEMD_DIR}/mihomo.service"  <<EOF
[Unit]
Description=mihomo proxy service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${INSTALL_DIR}/mihomo -d ${config_dir}
Restart=on-failure
RestartSec=5s
StartLimitIntervalSec=60
StartLimitBurst=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload 2>/dev/null || true

    log_info "Installation complete!"
    echo ""
    echo "Start mihomo:"
    echo "  sudo mihomoctl start"
}

do_config() {
    local subcommand="${1:-}"

    if [ -z "$subcommand" ]; then
        log_info "Available commands:"
        echo "  mihomoctl config add <name> <url>          - Add profile source"
        echo "  mihomoctl config remove <name>             - Remove source, manual config, or profile"
        echo "  mihomoctl config list                      - List sources, profiles, and manual configs"
        echo "  mihomoctl config download <source> [--ua]  - Download profile (--ua: preset or custom UA)"
        echo "  mihomoctl config select <name_or_path>     - Apply a config (by name or file path)"
        echo "  mihomoctl config create <name>             - Create a new manual config from template"
        echo "  mihomoctl config edit <name>               - Edit a manual config file"
        echo "  mihomoctl config show                      - Show current active config details"
        echo ""
        echo "User-Agent presets: clash, clashmeta, mihomo, surge, quantumult, shadowrocket, mozilla, chrome, curl"
        echo "Use --list-ua to see all presets"
        return 0
    fi

    case "$subcommand" in
        add)
            do_config_add "$2" "$3"
            ;;
        remove)
            do_config_remove "$2"
            ;;
        list)
            do_config_list
            ;;
        download)
            shift
            do_config_download "$@"
            ;;
        select)
            do_config_select "$2"
            ;;
        create)
            do_config_create "$2"
            ;;
        edit)
            do_config_edit "$2"
            ;;
        show)
            do_config_show
            ;;
        *)
            log_error "Unknown config command: $subcommand"
            return 1
            ;;
    esac
}

do_config_add() {
    local name="${1:-}"
    local source="${2:-}"

    if [ -z "$name" ] || [ -z "$source" ]; then
        log_error "Missing arguments"
        echo "Usage: mihomoctl config add <name> <url>"
        echo "       mihomoctl config add <name> <file_path>"
        echo ""
        echo "Examples:"
        echo "  mihomoctl config add mysub https://sub.example.com/api?token=xxx"
        echo "  sudo mihomoctl config add myconfig ./my-mihomo-config.yaml"
        return 1
    fi

    # If the source is an existing file, add it as a manual config
    if [ -f "$source" ]; then
        check_root "config add $name $source"

        mkdir -p "$MANUAL_CONFIG_DIR"
        local config_file="${MANUAL_CONFIG_DIR}/${name}.yaml"

        if [ -f "$config_file" ]; then
            log_error "Config '$name' already exists at $config_file"
            echo "Use 'sudo mihomoctl config remove $name' to remove it first"
            return 1
        fi

        cp "$source" "$config_file"
        log_info "Added manual config: $name ($(du -h "$config_file" | cut -d' ' -f1))"
        echo ""
        echo "Edit it:   sudo mihomoctl config edit $name"
        echo "Apply it:  sudo mihomoctl config select $name"
        return 0
    fi

    # Otherwise, treat it as a URL source
    local sources_file
    sources_file=$(get_sources_file)
    mkdir -p "$(dirname "$sources_file")"

    if [ -f "$sources_file" ] && grep -q "^${name}|" "$sources_file"; then
        log_error "Source '$name' already exists"
        echo "Use 'mihomoctl config remove $name' to remove it first"
        return 1
    fi

    echo "${name}|${source}" >>"$sources_file"
    log_info "Added source: $name"
    log_debug "URL: $source"
    echo ""
    echo "Sources file: $sources_file"
    echo ""
    echo "Download profile:"
    echo "  mihomoctl config download $name"
}

do_config_remove() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        log_error "Source or config name required"
        echo "Usage: mihomoctl config remove <name>"
        echo ""
        echo "Removes a source, manual config, or downloaded profile by name."
        return 1
    fi

    local found=0

    # 1. Check profile sources
    local sources_file
    sources_file=$(get_sources_file)
    if [ -f "$sources_file" ] && grep -q "^${name}|" "$sources_file"; then
        sed -i "/^${name}|/d" "$sources_file"
        log_info "Removed source: $name"
        found=1
    fi

    # 2. Check manual configs
    if [ -f "${MANUAL_CONFIG_DIR}/${name}.yaml" ]; then
        rm -f "${MANUAL_CONFIG_DIR}/${name}.yaml"
        log_info "Removed manual config: ${name}.yaml"
        found=1
    fi

    # 3. Check downloaded profiles (glob match)
    if [ -d "$CONFIG_REPO_DIR" ]; then
        for f in "$CONFIG_REPO_DIR"/*"${name}"*; do
            [ -f "$f" ] || continue
            rm -f "$f"
            log_info "Removed profile: $(basename "$f")"
            found=1
        done
    fi

    if [ "$found" -eq 0 ]; then
        log_error "No source, manual config, or profile found matching '$name'"
        return 1
    fi
}

do_config_list() {
    local sources_file
    sources_file=$(get_sources_file)

    echo ""
    echo "=== Profile Sources ==="
    echo ""

    if [ -f "$sources_file" ] && [ -s "$sources_file" ]; then
        echo "Configured sources:"
        while IFS='|' read -r name url; do
            echo "  $name"
            echo "    URL: $url"
        done <"$sources_file"
    else
        echo "No sources configured"
        echo ""
        echo "Add a source:"
        echo "  mihomoctl config add <name> <url>"
    fi

    echo ""
    echo "=== Downloaded Profiles ==="
    echo ""

    if [ -d "$CONFIG_REPO_DIR" ] && [ -n "$(ls -A "$CONFIG_REPO_DIR" 2>/dev/null)" ]; then
        # shellcheck disable=SC2012
        ls -lh "$CONFIG_REPO_DIR" | tail -n +2 | awk '{printf "  %s (%s)\n", $9, $5}'
    else
        echo "  (no profiles downloaded)"
    fi

    echo ""
    echo "=== Manual Configs ==="
    echo ""

    if [ -d "$MANUAL_CONFIG_DIR" ] && [ -n "$(ls -A "$MANUAL_CONFIG_DIR" 2>/dev/null)" ]; then
        # shellcheck disable=SC2012
        ls -lh "$MANUAL_CONFIG_DIR" | tail -n +2 | awk '{printf "  %s (%s)\n", $9, $5}'
    else
        echo "  (no manual configs created)"
        echo ""
        echo "Create a manual config:"
        echo "  mihomoctl config create <name>"
    fi

    echo ""
    echo "=== Current Active Config ==="
    echo ""

    local source_file="${CONFIG_DIR}/.source"
    local config_file="${CONFIG_DIR}/config.yaml"

    if [ -f "$source_file" ]; then
        # shellcheck disable=SC1090,SC2154
        source "$source_file"
        echo "  Using: $source_name ($source_type)"
        # shellcheck disable=SC2154
        echo "  Applied: $applied_at"
        # shellcheck disable=SC2154
        echo "  From: $source_path"
    elif [ -f "$config_file" ]; then
        local header_source
        header_source=$(grep "^# Applied from:" "$config_file" 2>/dev/null | head -1)
        local header_path
        header_path=$(grep "^# Source path:" "$config_file" 2>/dev/null | head -1)

        if [ -n "$header_source" ]; then
            echo "  ${header_source#\# }"
            if [ -n "$header_path" ]; then
                echo "  $(echo "$header_path" | sed 's/^# /')"
            fi
        else
            echo "  ${config_file} (no source tracking)"
        fi
    else
        echo "  (no config applied)"
    fi

    echo ""
    echo "Sources file: $sources_file"
}

do_config_download() {
    local source_name=""
    local custom_ua="${USER_AGENT}"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ua | --user-agent)
                if [ -z "$2" ]; then
                    log_error "--ua requires a User-Agent (preset name or custom string)"
                    list_ua_presets
                    return 1
                fi
                custom_ua=$(get_ua "$2")
                shift 2
                ;;
            --list-ua)
                list_ua_presets
                return 0
                ;;
            -*)
                log_error "Unknown option: $1"
                echo "Usage: mihomoctl config download <source_name> [--ua <ua>] [--list-ua]"
                return 1
                ;;
            *)
                source_name="$1"
                shift
                ;;
        esac
    done

    if [ -z "$source_name" ]; then
        log_error "Source name required"
        echo "Usage: mihomoctl config download <source_name> [--ua <preset|custom>] [--list-ua]"
        echo ""
        echo "Examples:"
        echo "  mihomoctl config download mysub"
        echo "  mihomoctl config download mysub --ua mozilla"
        echo "  mihomoctl config download mysub --ua 'MyCustomAgent/1.0'"
        echo ""
        list_ua_presets
        return 1
    fi

    local sources_file
    sources_file=$(get_sources_file)

    if [ ! -f "$sources_file" ]; then
        log_error "No sources configured"
        echo "Add a source first: mihomoctl config add <name> <url>"
        return 1
    fi

    local source_line
    source_line=$(grep "^${source_name}|" "$sources_file")
    if [ -z "$source_line" ]; then
        log_error "Source '$source_name' not found"
        echo "Available sources:"
        cut -d'|' -f1 "$sources_file" | sed 's/^/  /'
        return 1
    fi

    local url
    url=$(echo "$source_line" | cut -d'|' -f2)

    mkdir -p "$CONFIG_REPO_DIR"

    local output_file
    output_file="${CONFIG_REPO_DIR}/${source_name}-$(date +%Y%m%d-%H%M%S).yaml"

    echo ""
    echo "=== Download Target ==="
    echo "  Source:  $source_name"
    echo "  URL:     $url"
    echo "  Save to: $output_file"
    echo "  UA:      $custom_ua"
    echo ""

    local tmpfile="${output_file}.tmp"
    local http_code

    log_info "Downloading..."

    http_code=$(curl -w "%{http_code}" -k -L -A "$custom_ua" --connect-timeout 30 -m 60 -o "$tmpfile" "$url" 2>&1 | tail -n1)

    if [ -z "$http_code" ]; then
        http_code="000"
    fi

    log_debug "HTTP Code: $http_code"

    if [ "$http_code" != "200" ]; then
        log_error "Failed to download profile (HTTP $http_code)"

        if [ -f "$tmpfile" ] && [ -s "$tmpfile" ]; then
            local body_size
            body_size=$(wc -c <"$tmpfile"  2>/dev/null || echo 0)
            echo ""
            echo "=== Response Body (first 500 bytes) ==="

            if [ "$body_size" -gt 500 ]; then
                head -c 500 "$tmpfile" 2>/dev/null
                echo ""
                echo "... (total ${body_size} bytes)"
            else
                cat "$tmpfile" 2>/dev/null
            fi
            echo ""

            if head -c 10 "$tmpfile" 2>/dev/null | grep -q "{"; then
                if command -v jq >/dev/null 2>&1; then
                    echo "Parsed JSON:"
                    jq '.' "$tmpfile" 2>/dev/null | head -20 || cat "$tmpfile" | head -20
                    echo ""
                fi
            fi
        fi

        if [ "$http_code" = "404" ]; then
            log_error "Profile not found (404)"
        elif [ "$http_code" = "401" ] || [ "$http_code" = "403" ]; then
            log_error "Authentication failed ($http_code). Check URL for source '$source_name'"
        elif [ "$http_code" = "000" ]; then
            log_error "Connection failed. Check URL: $url"
        else
            log_error "Server error. Response code: $http_code"
        fi

        rm -f "$tmpfile"
        return 1
    fi

    if [ ! -f "$tmpfile" ] || [ ! -s "$tmpfile" ]; then
        log_error "Downloaded file is empty"
        rm -f "$tmpfile"
        return 1
    fi

    if ! head -c 100 "$tmpfile" | grep -qE "^(port|mixed-port|#|proxies)"; then
        log_error "Downloaded file appears to be invalid or incomplete"
        echo ""
        echo "=== First 200 bytes ==="
        head -c 200 "$tmpfile" 2>/dev/null
        echo ""
        echo ""
        rm -f "$tmpfile"
        return 1
    fi

    mv "$tmpfile" "$output_file"
    local size
    size=$(du -h "$output_file" | cut -d' ' -f1)
    log_info "Profile saved: $output_file ($size)"
    echo ""
    echo "To use this profile:"
    echo "  mihomoctl config select $output_file"
}

do_config_select_interactive() {
    local configs=()
    local types=()
    local files=()

    # Collect manual configs
    if [ -d "$MANUAL_CONFIG_DIR" ] && [ -n "$(ls -A "$MANUAL_CONFIG_DIR" 2>/dev/null)" ]; then
        for f in "$MANUAL_CONFIG_DIR"/*.yaml; do
            [ -f "$f" ] || continue
            configs+=("$(basename "$f")")
            types+=("manual")
            files+=("$f")
        done
    fi

    # Collect downloaded profiles
    if [ -d "$CONFIG_REPO_DIR" ] && [ -n "$(ls -A "$CONFIG_REPO_DIR" 2>/dev/null)" ]; then
        for f in "$CONFIG_REPO_DIR"/*.yaml; do
            [ -f "$f" ] || continue
            configs+=("$(basename "$f")")
            types+=("profile")
            files+=("$f")
        done
    fi

    if [ ${#configs[@]} -eq 0 ]; then
        log_error "No configs available"
        echo "Download or create a config first:"
        echo "  mihomoctl config download <source>"
        echo "  mihomoctl config create <name>"
        return 1
    fi

    # Display detailed menu
    echo ""
    echo "Available configs:"
    echo ""

    local i=1
    for config in "${configs[@]}"; do
        local file="${files[i - 1]}"
        local size
        size=$(du -h "$file" | cut -d' ' -f1)
        local timestamp
        timestamp=$(stat -c %y "$file" 2>/dev/null | cut -d' ' -f1)

        printf "%2d) [%-7s] %s (%s, %s)\n" \
            "$i" "${types[i - 1]}" "$config" "$size" "$timestamp"
        i=$((i + 1))
    done

    echo ""
    echo "Or enter file path directly"
    echo ""

    # Read user selection
    local selection
    read -p "Select config [1-${#configs[@]}] or path: " -r selection

    # Check if numeric selection
    if [[ $selection =~ ^[0-9]+$   ]] &&
        [ "$selection" -ge 1 ] &&
        [ "$selection" -le ${#configs[@]} ]; then
        local selected_file="${files[selection - 1]}"
        log_info "Selected: ${configs[selection - 1]}"
        apply_config "$selected_file"
    elif [ -f "$selection" ]; then
        # User entered file path
        log_info "Using file path: $selection"
        apply_config "$selection"
    else
        log_error "Invalid selection: $selection"
        return 1
    fi
}

apply_config() {
    local profile_path="$1"
    local source_name
    source_name=$(basename "$profile_path")
    local source_type=""

    if [[ $profile_path == "${MANUAL_CONFIG_DIR}/"*   ]]; then
        source_type="manual"
    elif [[ $profile_path == "${CONFIG_REPO_DIR}/"*   ]]; then
        source_type="profile"
    else
        source_type="external"
    fi

    log_info "Applying profile: $source_name ($source_type)"

    if [ -f "${CONFIG_DIR}/config.yaml" ]; then
        cp "${CONFIG_DIR}/config.yaml" "${CONFIG_DIR}/config.yaml.bak"
        log_debug "Backed up previous config: ${CONFIG_DIR}/config.yaml.bak"
    fi

    cp "$profile_path" "${CONFIG_DIR}/config.yaml"
    log_info "Applied config: $source_name"

    if ! grep -q "^port:" "${CONFIG_DIR}/config.yaml" 2>/dev/null &&
        ! grep -q "^mixed-port:" "${CONFIG_DIR}/config.yaml" 2>/dev/null; then
        log_error "Configuration format invalid (missing port settings)"
        log_info "Restoring previous config..."
        if [ -f "${CONFIG_DIR}/config.yaml.bak" ]; then
            cp "${CONFIG_DIR}/config.yaml.bak" "${CONFIG_DIR}/config.yaml"
        fi
        return 1
    fi

    ensure_allow_lan "${CONFIG_DIR}/config.yaml"

    local header_comment
    header_comment="# Applied from: $source_name ($source_type)
# Source path: $profile_path
# Applied at: $(date +%Y-%m-%d_%H:%M:%S)
# Managed by mihomoctl

"

    local tmp_config
    tmp_config=$(mktemp)
    echo "$header_comment" >"$tmp_config"
    cat "${CONFIG_DIR}/config.yaml" >>"$tmp_config"
    mv "$tmp_config" "${CONFIG_DIR}/config.yaml"

    cat >"${CONFIG_DIR}/.source"  <<EOF
source_path=$profile_path
source_name=$source_name
source_type=$source_type
applied_at=$(date +%Y-%m-%d_%H:%M:%S)
EOF

    log_info "Config applied successfully (source tracked in header and .source)"

    if systemctl is-active --quiet mihomo 2>/dev/null; then
        log_info "Restarting mihomo service..."
        systemctl restart mihomo
        sleep 1
        if systemctl is-active --quiet mihomo 2>/dev/null; then
            log_info "Service restarted successfully"
        else
            log_error "Service restart failed"
            return 1
        fi
    else
        log_info "Mihomo service is not running"
        echo "Start it with: mihomoctl start"
    fi
}

do_config_select() {
    local target="${1:-}"

    if [ -z "$target" ]; then
        do_config_select_interactive
        return 0
    fi

    local profile_path=""

    # If argument is an existing file, use it directly
    if [ -f "$target" ]; then
        profile_path="$target"
    else
        # Search by name: manual configs first (exact), then downloaded profiles (glob)
        if [ -f "${MANUAL_CONFIG_DIR}/${target}.yaml" ]; then
            profile_path="${MANUAL_CONFIG_DIR}/${target}.yaml"
        elif [ -f "${MANUAL_CONFIG_DIR}/${target}" ]; then
            profile_path="${MANUAL_CONFIG_DIR}/${target}"
        else
            for f in "$CONFIG_REPO_DIR"/*"${target}"*; do
                [ -f "$f" ] || continue
                profile_path="$f"
                break
            done
        fi
    fi

    if [ -z "$profile_path" ] || [ ! -f "$profile_path" ]; then
        log_error "Config not found: $target"
        echo ""
        echo "Available:"
        do_config_list_configs
        return 1
    fi

    apply_config "$profile_path"
}

do_config_create() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        log_error "Config name required"
        echo "Usage: mihomoctl config create <name>"
        echo ""
        echo "Creates a new manual config file from a default template."
        echo "Edit it afterward with: sudo mihomoctl config edit $name"
        return 1
    fi

    # Validate name (alphanumeric, hyphens, underscores only)
    if ! echo "$name" | grep -qE '^[a-zA-Z0-9_-]+$'; then
        log_error "Invalid config name. Use only letters, numbers, hyphens, and underscores."
        return 1
    fi

    mkdir -p "$MANUAL_CONFIG_DIR"
    local config_file="${MANUAL_CONFIG_DIR}/${name}.yaml"

    if [ -f "$config_file" ]; then
        log_error "Config '$name' already exists at $config_file"
        echo "Edit it: sudo mihomoctl config edit $name"
        return 1
    fi

    cat >"$config_file"  <<'MANUAL_EOF'
# mihomo manual configuration
mixed-port: 7890
allow-lan: true
mode: rule
log-level: info
external-controller: 127.0.0.1:9090

# Proxy nodes
proxies:

# Proxy groups
proxy-groups:
  - name: Proxy
    type: select
    proxies:
      - DIRECT

# Rules
rules:
  - MATCH,Proxy
MANUAL_EOF

    log_info "Created manual config: $config_file"
    echo ""
    echo "Edit this file:"
    echo "  sudo mihomoctl config edit $name"
    echo ""
    echo "Apply it:"
    echo "  sudo mihomoctl config select $name"
}

do_config_edit() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        log_error "Config name required"
        echo "Usage: mihomoctl config edit <name>"
        echo ""
        echo "Opens the config file in your default editor (\$EDITOR, defaults to vim)."
        echo ""
        echo "Available:"
        do_config_list_configs
        return 1
    fi

    local config_file=""

    # Strip .yaml extension if provided, then search
    local base_name="${name%.yaml}"

    if [ -f "${MANUAL_CONFIG_DIR}/${base_name}.yaml" ]; then
        config_file="${MANUAL_CONFIG_DIR}/${base_name}.yaml"
    elif [ -f "${MANUAL_CONFIG_DIR}/${name}" ]; then
        config_file="${MANUAL_CONFIG_DIR}/${name}"
    elif [ -f "${CONFIG_REPO_DIR}/${name}" ]; then
        config_file="${CONFIG_REPO_DIR}/${name}"
    elif [ -f "${CONFIG_REPO_DIR}/${name}.yaml" ]; then
        config_file="${CONFIG_REPO_DIR}/${name}.yaml"
    else
        log_error "Config '$name' not found"
        echo ""
        echo "Available:"
        do_config_list_configs
        return 1
    fi

    local editor="${EDITOR:-vim}"
    log_info "Opening $config_file with $editor..."

    # Force UTF-8 encoding for vim
    if [[ $editor =~ vim$   ]] || [[ $editor =~ vi$   ]]; then
        $editor -c 'set encoding=utf-8' "$config_file"
    else
        $editor "$config_file"
    fi
}

do_config_show() {
    local current="${CONFIG_DIR}/config.yaml"
    local source_file="${CONFIG_DIR}/.source"

    echo ""
    echo "=== Current Active Config ==="
    echo ""

    if [ ! -f "$current" ]; then
        echo "  No config file found at $current"
        return 0
    fi

    local size
    size=$(du -h "$current" | cut -d' ' -f1)
    echo "  Path: $current"
    echo "  Size: $size"
    echo ""

    echo "=== Source Tracking ==="
    echo ""

    local tracked_source=""
    local tracked_type=""
    local tracked_path=""

    if [ -f "$source_file" ]; then
        # shellcheck disable=SC1090,SC2154
        source "$source_file"
        tracked_source="$source_name"
        tracked_type="$source_type"
        tracked_path="$source_path"
        echo "  .source metadata:"
        echo "    Name: $source_name"
        echo "    Type: $source_type"
        echo "    Applied: $applied_at"
        echo "    Path: $source_path"
        echo ""
    fi

    local header_source
    header_source=$(grep "^# Applied from:" "$current" 2>/dev/null | head -1 | sed 's/^# //')
    local header_path
    header_path=$(grep "^# Source path:" "$current" 2>/dev/null | head -1 | sed 's/^# Source path: //')
    local header_time
    header_time=$(grep "^# Applied at:" "$current" 2>/dev/null | head -1 | sed 's/^# Applied at: //')

    if [ -n "$header_source" ]; then
        echo "  Config header comment:"
        echo "    $header_source"
        if [ -n "$header_path" ]; then
            echo "    Source: $header_path"
        fi
        if [ -n "$header_time" ]; then
            echo "    Time: $header_time"
        fi
        echo ""
    fi

    echo "=== Summary ==="
    echo ""

    if [ -n "$tracked_source" ] && [ -n "$header_source" ]; then
        if [ "$tracked_path" = "$header_path" ]; then
            echo "  ✓ Source tracking consistent"
            echo "    Using: $tracked_source ($tracked_type)"
        else
            echo "  ⚠ Source tracking mismatch detected"
            echo "    .source: $tracked_path"
            echo "    header:  $header_path"
            echo "  (config may have been edited or replaced manually)"
        fi
    elif [ -n "$tracked_source" ]; then
        echo "  Source: $tracked_source ($tracked_type) - from .source file"
    elif [ -n "$header_source" ]; then
        echo "  Source: $header_source - from header comment"
    else
        echo "  ⚠ No source tracking found"
        echo "  (config may have been created before tracking feature or edited manually)"
    fi

    echo ""
    echo "Key settings:"
    grep -E "^(port|mixed-port|socks-port|external-controller|mode|log-level):" "$current" | sed 's/^/  /'

    echo ""
    echo "Actions:"
    echo "  List configs:  mihomoctl config list"
    echo "  Switch:        sudo mihomoctl config select <name_or_path>"
    echo "  View header:   head -10 ${CONFIG_DIR}/config.yaml"
}

do_config_list_configs() {
    echo "Manual configs:"
    local manuals
    manuals=$(get_manual_configs)
    # shellcheck disable=SC2001
    [ -n "$manuals" ] && echo "$manuals" | sed 's/^/  /' || echo "  (none — create one: mihomoctl config create <name>)"

    echo ""
    echo "Downloaded profiles:"
    local profiles
    profiles=$(get_profile_configs)
    # shellcheck disable=SC2001
    [ -n "$profiles" ] && echo "$profiles" | sed 's/^/  /' || echo "  (none — download one: sudo mihomoctl config download <source>)"
}

do_start() {
    if ! [ -f "${INSTALL_DIR}/mihomo" ]; then
        log_error "Mihomo not installed. Run: mihomoctl install"
        return 1
    fi

    log_info "Starting mihomo service..."
    if systemctl start mihomo 2>/dev/null; then
        sleep 1
        if systemctl is-active --quiet mihomo 2>/dev/null; then
            log_info "Service started successfully"
            echo ""
            echo "Service status:"
            systemctl status mihomo --no-pager 2>/dev/null | head -10
        else
            log_error "Service failed to start"
            systemctl status mihomo --no-pager 2>/dev/null | head -20
            return 1
        fi
    else
        log_error "Failed to start service"
        return 1
    fi
}

do_stop() {
    log_info "Stopping mihomo service..."
    if systemctl stop mihomo 2>/dev/null; then
        sleep 1
        log_info "Service stopped"
    else
        log_error "Failed to stop service"
        return 1
    fi
}

do_restart() {
    log_info "Restarting mihomo service..."
    if systemctl restart mihomo 2>/dev/null; then
        sleep 1
        if systemctl is-active --quiet mihomo 2>/dev/null; then
            log_info "Service restarted successfully"
        else
            log_error "Service failed to restart"
            return 1
        fi
    else
        log_error "Failed to restart service"
        return 1
    fi
}

do_status() {
    if ! [ -f "${INSTALL_DIR}/mihomo" ]; then
        log_error "Mihomo not installed"
        return 1
    fi

    echo ""
    echo "=== Mihomo Service Status ==="
    echo ""

    if systemctl is-active --quiet mihomo 2>/dev/null; then
        echo "Status: ✓ Running"
    else
        echo "Status: ✗ Stopped"
    fi

    if systemctl is-enabled --quiet mihomo 2>/dev/null; then
        echo "Auto-start: ✓ Enabled"
    else
        echo "Auto-start: ✗ Disabled"
    fi

    echo ""
    echo "Configuration:"
    echo "  Binary: ${INSTALL_DIR}/mihomo"
    echo "  Config: ${CONFIG_DIR}/config.yaml"
    echo "  Cache: ${CACHE_DIR}"

    if [ -f "${CONFIG_DIR}/config.yaml" ]; then
        echo ""
        echo "Current config ports:"
        grep -E "^(port|mixed-port|socks-port|http-port):" "${CONFIG_DIR}/config.yaml" | sed 's/^/  /'
    fi

    echo ""
    echo "Service details:"
    systemctl --no-pager status mihomo 2>/dev/null
}

do_logs() {
    local lines="${1:-100}"
    local follow="${2:-}"

    if ! [ -f "${INSTALL_DIR}/mihomo" ]; then
        log_error "Mihomo not installed"
        return 1
    fi

    if [ "$follow" = "-f" ] || [ "$follow" = "--follow" ]; then
        log_info "Following mihomo service logs (press Ctrl+C to stop)..."
        journalctl -u mihomo -f
    else
        log_info "Showing last $lines lines of mihomo service logs..."
        journalctl -u mihomo --no-pager -n "$lines"
    fi
}

do_enable() {
    if ! [ -f "${INSTALL_DIR}/mihomo" ]; then
        log_error "Mihomo not installed. Run: mihomoctl install"
        return 1
    fi

    log_info "Enabling auto-start for mihomo service..."
    if systemctl enable mihomo 2>/dev/null; then
        log_info "Auto-start enabled"
        echo ""
        echo "Mihomo will start automatically on user login"
    else
        log_error "Failed to enable auto-start"
        return 1
    fi
}

do_disable() {
    log_info "Disabling auto-start for mihomo service..."
    if systemctl disable mihomo 2>/dev/null; then
        log_info "Auto-start disabled"
    else
        log_error "Failed to disable auto-start"
        return 1
    fi
}

do_uninstall() {
    log_info "Starting mihomo uninstallation..."

    if [ -z "${1:-}" ] || [ "$1" != "-f" ]; then
        read -p "Are you sure? (yes/no): " -r
        [[ $REPLY =~ ^[Yy][Ee][Ss]$ ]] || {
            log_info "Cancelled"
            return 0
        }
    fi

    systemctl stop mihomo 2>/dev/null || true
    systemctl disable mihomo 2>/dev/null || true
    rm -f "${SYSTEMD_DIR}/mihomo.service"
    systemctl daemon-reload 2>/dev/null || true
    rm -f "${INSTALL_DIR}/mihomo"
    rm -rf "$CONFIG_DIR" "$CACHE_DIR"

    log_info "Uninstallation complete!"
}

do_ui() {
    local subcommand="${1:-}"

    if [ -z "$subcommand" ]; then
        log_info "Available UI commands:"
        echo "  mihomoctl ui install     Install zashboard UI"
        echo "  mihomoctl ui update      Update UI to latest version"
        echo "  mihomoctl ui status      Show UI status"
        echo "  mihomoctl ui uninstall   Remove UI"
        return 0
    fi

    case "$subcommand" in
        install)
            do_ui_install
            ;;
        update)
            do_ui_update
            ;;
        status)
            do_ui_status
            ;;
        uninstall)
            do_ui_uninstall
            ;;
        *)
            log_error "Unknown UI command: $subcommand"
            return 1
            ;;
    esac
}

do_ui_install() {
    if [ ! -f "${INSTALL_DIR}/mihomo" ]; then
        log_error "Mihomo not installed. Run: mihomoctl install"
        return 1
    fi

    log_info "Installing zashboard UI..."
    mkdir -p "$UI_DIR"

    local tmpdir
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT

    log_info "Downloading zashboard..."
    local tmpfile="$tmpdir/dist.zip"

    # 尝试下载
    if ! curl -k -L -# -A "$USER_AGENT" --connect-timeout 30 -m 120 -o "$tmpfile" "$UI_REPO" 2>/dev/null; then
        log_error "Failed to download zashboard from primary URL, trying alternative..."
        # 备用 URL
        if ! curl -k -L -# -A "$USER_AGENT" --connect-timeout 30 -m 120 -o "$tmpfile" "https://github.com/Zephyruso/zashboard/releases/download/latest/dist.zip" 2>/dev/null; then
            log_error "Failed to download zashboard"
            return 1
        fi
    fi

    log_info "Extracting UI files..."
    cd "$tmpdir" || return

    # 检查 unzip 是否可用
    if command -v unzip >/dev/null 2>&1; then
        if ! unzip -q "$tmpfile" 2>/dev/null; then
            log_error "Failed to extract zashboard with unzip"
            return 1
        fi
    elif command -v python3 >/dev/null 2>&1; then
        # 使用 Python 解压
        if ! python3 -m zipfile -e "$tmpfile" . 2>/dev/null; then
            log_error "Failed to extract zashboard with python3"
            return 1
        fi
    else
        log_error "unzip or python3 is required"
        return 1
    fi

    # 查找 dist 目录
    local dist_dir
    if [ -d "$tmpdir/dist" ]; then
        dist_dir="$tmpdir/dist"
    else
        # 搜索 dist 目录
        dist_dir=$(find "$tmpdir" -maxdepth 3 -type d -name "dist" | head -1)
        if [ -z "$dist_dir" ]; then
            log_error "Invalid zashboard package - dist directory not found"
            return 1
        fi
    fi

    log_debug "Found dist at: $dist_dir"

    # 清除旧的 UI 文件
    rm -rf "${UI_DIR:?}"/*

    # 复制文件
    if ! cp -r "$dist_dir"/* "$UI_DIR/" 2>/dev/null; then
        log_error "Failed to install UI files"
        return 1
    fi

    trap - EXIT

    # 更新配置文件
    if [ -f "${CONFIG_DIR}/config.yaml" ]; then
        if ! grep -q "external-ui:" "${CONFIG_DIR}/config.yaml"; then
            echo "external-ui: $UI_DIR" >>"${CONFIG_DIR}/config.yaml"
            log_info "Updated config.yaml"
        fi
    fi

    local size
    size=$(du -sh "$UI_DIR" | cut -d' ' -f1)
    log_info "UI installed successfully: $size"
    echo ""
    echo "UI path: $UI_DIR"
    echo "Access: http://127.0.0.1:9090/ui/"
    echo ""
    echo "To apply changes:"
    echo "  mihomoctl restart"
}

do_ui_update() {
    if [ ! -d "$UI_DIR" ]; then
        log_error "UI not installed. Run: mihomoctl ui install"
        return 1
    fi

    log_info "Updating zashboard UI..."
    do_ui_install
}

do_ui_status() {
    if [ ! -d "$UI_DIR" ]; then
        echo "UI Status: ✗ Not installed"
        return 0
    fi

    echo "UI Status: ✓ Installed"
    echo "UI Path: $UI_DIR"
    echo "UI Size: $(du -sh "$UI_DIR" | cut -d' ' -f1)"

    if [ -f "${CONFIG_DIR}/config.yaml" ]; then
        if grep -q "external-ui:" "${CONFIG_DIR}/config.yaml"; then
            echo "Config: ✓ Configured in config.yaml"
            echo "Access: http://127.0.0.1:9090/ui/"
        else
            echo "Config: ⚠ Not configured"
            echo "Run: mihomoctl restart"
        fi
    fi
}

do_ui_uninstall() {
    if [ ! -d "$UI_DIR" ]; then
        log_info "UI not installed"
        return 0
    fi

    log_info "Removing zashboard UI..."
    rm -rf "$UI_DIR"

    if [ -f "${CONFIG_DIR}/config.yaml" ]; then
        sed -i '/^external-ui:/d' "${CONFIG_DIR}/config.yaml"
    fi

    log_info "UI uninstalled successfully"
}

