}

case "${1:-}" in
    install)
        shift
        do_install "$@"
        ;;
    uninstall)
        do_uninstall "${2:-}"
        ;;
    start)
        do_start
        ;;
    stop)
        do_stop
        ;;
    restart)
        do_restart
        ;;
    status)
        do_status
        ;;
    logs)
        do_logs "${2:-}" "${3:-}"
        ;;
    enable)
        do_enable
        ;;
    disable)
        do_disable
        ;;
    config)
        shift
        do_config "$@"
        ;;
    ui)
        do_ui "$2"
        ;;
    --list-ua)
        list_ua_presets
        ;;
    -h | --help)
        show_help
        ;;
    -v | --verbose)
        VERBOSE=1
        shift
        "$0" "$@"
        ;;
    *)
        [ -z "$1" ] && show_help || echo "Unknown command: $1"
        ;;
esac
